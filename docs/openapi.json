                  "phone"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Maria Silva"
                  },
                  "cpf": {
                    "type": "string",
                    "example": "123.456.789-00"
                  },
                  "phone": {
                    "type": "string",
                    "example": "(11) 99999-9999"
                  },
                  "email": {
                    "type": "string",
                    "example": "maria@email.com"
                  },
                  "zipCode": {
                    "type": "string",
                    "example": "01310-100"
